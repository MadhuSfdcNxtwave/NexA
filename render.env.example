# =============================================================================
# Render — paste this ENTIRE file via: Environment → Add from .env
# API service only (nexa-gays). Do NOT add DATABASE_URL (Render sets it).
# Replace PASTE_... placeholders, then paste once instead of adding vars one-by-one.
# Or run:  cd backend && .\export-render-env.ps1 -CopyToClipboard
# =============================================================================

# --- GCP ---
GCP_PROJECT=kossip-helpers
BQ_LOCATION=asia-south1
BQ_DEFAULT_DATASET=academy_success_ai_analytics_worksapce
# Add all tables from BQ_DEFAULT_DATASET to workspace catalog on API startup (missing only)
SYNC_WORKSPACE_FROM_DATASET=1
VERTEX_LOCATION=us-central1
GCP_SA_KEY_JSON=PASTE_FULL_gcp-sa-config.json_ON_ONE_LINE

# --- Models (OpenRouter — same as local) ---
FETCH_PROVIDER=openai
VIZ_PROVIDER=openai
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=PASTE_YOUR_OPENROUTER_KEY
FETCH_MODEL=openai/gpt-4o-mini
VIZ_MODEL=openai/gpt-4o-mini
OPENAI_MAX_TOKENS=4096
VIZ_MAX_TOKENS=4096

# --- Auth ---
JWT_SECRET=PASTE_LONG_RANDOM_SECRET
JWT_EXPIRE_MINUTES=10080
ADMIN_EMAIL=you@nxtwave.co.in
ADMIN_PASSWORD=YourSecurePassword
DEFAULT_USER_CREDITS=100
CREDITS_PER_GB=1

# --- CORS (frontend URL) ---
CORS_ORIGINS=https://nexa.onrender.com

# --- Pipeline ---
HEX_STYLE_PIPELINE=true
SQL_VERIFY_WITH_LLM=false
SQL_MAX_ATTEMPTS=3
EMBEDDING_RETRIEVAL_ENABLED=false
ASK_DEBUG_LOG=false
MEMORY_CONTEXT_SIZE=12
THREAD_CONVERSATION_TURNS=8
