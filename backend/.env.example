# Copy to .env for local development. On Render, set these in the dashboard.

# --- GCP ---
GCP_PROJECT=your-gcp-project-id
BQ_LOCATION=US
VERTEX_LOCATION=us-central1

# Locally, leave GCP_SA_KEY_JSON empty and run:
#   gcloud auth application-default login
# On Render, paste the entire service-account JSON on one line here:
GCP_SA_KEY_JSON=

# --- Models ---
# FETCH role (NL -> SQL). vertex (default) or openai.
FETCH_PROVIDER=vertex
FETCH_MODEL=gemini-2.5-flash
# If FETCH_PROVIDER=openai, also set:
# FETCH_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# VIZ role (chart + analysis) — always Vertex AI:
VIZ_MODEL=gemini-2.5-pro

# --- App ---
# Local dev uses SQLite by default. On Render this is set from the database.
DATABASE_URL=sqlite:///./hexlite.db
# Allow your frontend origin (comma-separated). Use * for local dev.
CORS_ORIGINS=*
