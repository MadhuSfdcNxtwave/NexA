# =============================================================================
# NexA backend — copy this file to .env
# =============================================================================

# --- GCP (required) ----------------------------------------------------------
GCP_PROJECT=kossip-helpers
BQ_LOCATION=asia-south1
# NexA warehouse dataset (only this dataset is browsed when set)
BQ_DEFAULT_DATASET=academy_success_ai_analytics_worksapce
VERTEX_LOCATION=us-central1

# --- GCP service account key (required for BigQuery) -------------------------
GCP_SA_KEY_FILE=./ccbp-academy-daily-reports-key.json
GCP_SA_KEY_JSON=                                      # leave empty locally; Render only

# --- AI models — SQL generation + presentation --------------------------------
# SQL (FETCH) — pick one SDK provider:
#   gemini    -> Google GenAI SDK (Vertex via GCP_PROJECT, or GEMINI_API_KEY)
#   openai    -> OpenAI SDK (OpenAI API or OpenRouter via OPENAI_BASE_URL)
#   anthropic -> Anthropic SDK (native Claude)
#
# Recommended SQL models:
#   gemini:    gemini-2.5-flash
#   openai:    gpt-4o-mini  (OpenRouter: openai/gpt-4o-mini)
#   anthropic: claude-sonnet-4-20250514
FETCH_PROVIDER=openai
# SQL_PROVIDER=anthropic                 # optional: override FETCH_PROVIDER for SQL only
FETCH_MODEL=openai/gpt-4o-mini

# Presentation (charts + analysis) — Hex-style: use a fast/cheap model here
VIZ_PROVIDER=openai
VIZ_MODEL=openai/gpt-4o-mini

# OpenAI SDK (also OpenRouter when OPENAI_BASE_URL is set)
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-...
OPENAI_MAX_TOKENS=4096

# Anthropic SDK — set when FETCH_PROVIDER or VIZ_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MAX_TOKENS=4096

# Google GenAI SDK — Vertex uses GCP_PROJECT above; or set GEMINI_API_KEY for AI Studio
# FETCH_PROVIDER=gemini
# FETCH_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=

VIZ_MAX_TOKENS=4096
VIZ_FALLBACK_MODELS=anthropic/claude-sonnet-4,openai/gpt-4o

# --- App ---------------------------------------------------------------------
DATABASE_URL=sqlite:///./hexlite.db
CORS_ORIGINS=*

# --- Auth (admin creates users; first admin bootstrapped from env) -----------
# Generate a long random string for production, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080
# First admin is bootstrapped from these on startup — set to your own values
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
DEFAULT_USER_CREDITS=100
CREDITS_PER_GB=1

# Optional BigQuery caps (bytes billed per query)
# PREVIEW_MAX_BYTES_BILLED=16106127360   # 15 GB — row preview on large views
# MAX_BYTES_BILLED=2147483648            # 2 GB — Ask / generated SQL

# --- Hex-style pipeline (fewer LLM calls, compact context) -------------------
# When true (default), NexA matches Hex's pattern: retrieval routing, compact schema,
# dry-run SQL verification (no LLM verify per attempt), heuristic charts + 1 analysis.
HEX_STYLE_PIPELINE=true
# TABLE_ROUTER_MODE=retrieval   # retrieval | vector | llm | hybrid
# EMBEDDING_RETRIEVAL_ENABLED=true
# EMBEDDING_PROVIDER=gemini      # gemini (Vertex/AI Studio) | openai
# EMBEDDING_MODEL=gemini-embedding-001
# EMBEDDING_TOP_K=3
# EMBEDDING_MIN_SCORE=0.28
# EMBEDDING_AUTO_INDEX_ON_STARTUP=true
# Fused routing: search all tables via embeddings + keyword, LLM picks from top 8
# ROUTING_FUSION_ENABLED=true
# ROUTING_TOP_K=8
# ROUTING_METADATA_BACKUP_ENABLED=true
# ROUTING_METADATA_MIN_SCORE=20
# ROUTING_METADATA_SCORE_GAP=12
# EMBEDDING_TOP_K=8
# EMBEDDING_MIN_SCORE=0.22
# Legacy full-article KB router (off when fusion enabled)
# KB_AI_ROUTING=false
# SCHEMA_CONTEXT_MAX_CHARS=4500
# SCHEMA_MAX_COLUMNS_PER_TABLE=28
# PRESENTATION_MODE=hex         # hex = infer chart + analyze | full = + chart LLM + suggest LLM
# CACHE_ROUTER_MODE=rules       # rules | llm
# SQL_CHAIN_PLANNER=rules       # rules | llm
# Domain SQL templates (NPS/feedback/overview shortcuts). Default false: the
# generic LLM pipeline answers from any table's schema — recommended for 40+ tables.
# SQL_TEMPLATES_ENABLED=false

# SQL accuracy + Cursor-style thread memory
# Hex defaults: SQL_MAX_ATTEMPTS=3, SQL_VERIFY_WITH_LLM=false
SQL_MAX_ATTEMPTS=3
SQL_MAX_ATTEMPTS_CAP=5
SQL_RETRY_STALE_LIMIT=2
SQL_VERIFY_WITH_LLM=false
REQUIRE_SQL_APPROVAL=false
ASK_CLARIFICATION_ENABLED=true
SQL_CHAIN_ENABLED=true
SQL_CHAIN_MAX_STEPS=5
CACHE_ANSWER_ENABLED=true
CACHE_LOOKUP_SIZE=12
MEMORY_CONTEXT_SIZE=12
THREAD_CONVERSATION_TURNS=8

# Agent pipeline (self-learning + query critic)
AGENTS_PIPELINE_ENABLED=true
ENABLE_STREAMING=true
SCHEMA_CACHE_TTL_HOURS=6
PATTERN_MINER_MATCH_THRESHOLD=0.65
PATTERN_MINER_REFRESH_MINUTES=30
PATTERN_MINER_MIN_OCCURRENCES=3
TEMPLATE_PROMOTER_THRESHOLD=3
SQL_MODEL_SIMPLE=claude-haiku-4-5
SQL_MODEL_COMPLEX=claude-sonnet-4-6
SQL_MODEL_CRITIC=gemini-2.5-flash
SQL_MODEL_VIZ=claude-haiku-4-5
SQL_MODEL_BATCH=gemini-2.5-pro

# Verbose ask tracing → backend/ask-debug.log + console ([ASK] lines)
ASK_DEBUG_LOG=false
MEMORY_MAX_ROWS=500
NOTEBOOK_MAX_ROWS=2000

# Workspace tables (comma-separated) — auto-seeded when catalog is empty; shared by all projects
DEFAULT_WORKSPACE_TABLES=kossip-helpers.academy_success_ai_analytics_worksapce.academy_nps_form_responses,kossip-helpers.academy_success_ai_analytics_worksapce.users_contextual_feedback_details,kossip-helpers.academy_success_ai_analytics_worksapce.nps_form_responses_nov_and_dec_2025,kossip-helpers.academy_success_ai_analytics_worksapce.z_ccbp_academy_users_master_data,kossip-helpers.academy_success_ai_analytics_worksapce.z_ccbp_users_cloudwatch_interactions_with_nav_bar
# On startup, add every table in BQ_DEFAULT_DATASET not already in the catalog (recommended for Render)
SYNC_WORKSPACE_FROM_DATASET=1
